    {
      "name": "Schema Validation",
      "item": [
        {
          "name": "New Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Define The Schema\r",
                  "const movieSchema = {\r",
                  "    \"type\": \"object\",\r",
                  "    \"required\": [\"id\", \"original_title\", \"runtime\", \"genres\"],\r",
                  "    \"properties\": {\r",
                  "        \"id\": { \"type\": \"number\" },\r",
                  "        \"original_title\": { \"type\": \"string\" },\r",
                  "        \"runtime\": { \"type\": \"number\" },\r",
                  "        \"genres\": { \r",
                  "            \"type\": \"array\",\r",
                  "            \"items\": {\r",
                  "                \"type\": \"object\",\r",
                  "                \"properties\": {\r",
                  "                    \"id\": { \"type\": \"number\" },\r",
                  "                    \"name\": { \"type\": \"string\" }\r",
                  "                }\r",
                  "            }\r",
                  "        },\r",
                  "        \"adult\": { \"type\": \"boolean\" }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "// 2. Perform the Validation\r",
                  "pm.test(\"Response Schema is Valid\", function () {\r",
                  "    pm.response.to.have.jsonSchema(movieSchema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
