  "item": [
    {
      "name": "Auth & Smoke Test",
      "item": [
        {
          "name": "1: Authentication Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Basic HTTP Check\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Simple Boolean Check\r",
                  "pm.test(\"API Token is Authorized\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.success).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.themoviedb.org/3/authentication",
              "protocol": "https",
              "host": [
                "api",
                "themoviedb",
                "org"
              ],
              "path": [
                "3",
                "authentication"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2: Basic Search - Interstellar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status and Response Time Check \r",
                  "pm.test(\"Search is functional and fast\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000); // Response should be < 1s\r",
                  "});\r",
                  "\r",
                  "// 2. Data Integrity Check\r",
                  "pm.test(\"Results found for Interstellar\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.results.length).to.be.above(0);\r",
                  "    pm.expect(jsonData.results[0].title).to.contain(\"Interstellar\");\r",
                  "    \r",
                  "    // 3. Dynamic Chaining \r",
                  "    var firstId = jsonData.results[0].id;\r",
                  "    pm.environment.set(\"firstResultId\", firstId);\r",
                  "    console.log(\"Successfully captured Movie ID: \" + firstId);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.themoviedb.org/3/search/movie?query=Interstellar&api_key={{api_key}}",
              "protocol": "https",
              "host": [
                "api",
                "themoviedb",
                "org"
              ],
              "path": [
                "3",
                "search",
                "movie"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "Interstellar"
                },
                {
                  "key": "api_key",
                  "value": "{{api_key}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Regression Suite",
      "item": [
        {
          "name": "1: Get Movie Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
                  "\r",
                  "pm.test(\"Movie Details are Correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    // Verify the title we saved is the one we got\r",
                  "    pm.expect(jsonData.original_title).to.include(\"Interstellar\");\r",
                  "    // Verify technical data types \r",
                  "    pm.expect(jsonData.runtime).to.be.a('number');\r",
                  "    pm.expect(jsonData.genres).to.be.an('array');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.themoviedb.org/3/movie/{{firstResultId}}?api_key={{api_key}}",
